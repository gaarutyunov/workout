# Public OAuth client identifiers (no secrets — PKCE flow). Safe to commit values
# for your own deployment; left blank here. These are the ONLY build-time config.

# Dropbox app key (App folder, scoped access). Registered once by the developer.
VITE_DROPBOX_APP_KEY=

# OpenRouter OAuth client id (optional — users may instead paste an API key).
VITE_OPENROUTER_CLIENT_ID=

# Override the Vite base path (defaults to /workout/ for GitHub Pages).
# VITE_BASE=/workout/
